<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:HostsManager.ViewModels"
             x:Class="HostsManager.Views.BackupView"
             x:DataType="vm:BackupViewModel">

    <Grid RowDefinitions="Auto,*,Auto">
        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="备份管理" Classes="pageTitle" Margin="0,0,0,6"/>
            <TextBlock Text="双击备份项可预览内容，恢复前会自动备份当前 Hosts"
                      Classes="pageSubtitle"/>
        </StackPanel>

        <Border Grid.Row="1" Classes="card" Padding="12">
            <Grid>
                <TextBlock Text="暂无备份，保存 Hosts 后将自动创建"
                          Classes="pageSubtitle"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Center"
                          IsVisible="{Binding IsBackupListEmpty}"/>

                <ListBox ItemsSource="{Binding Backups}"
                        SelectedItem="{Binding SelectedBackup}"
                        Background="Transparent"
                        BorderThickness="0"
                        IsVisible="{Binding !IsBackupListEmpty}"
                        DoubleTapped="OnBackupDoubleTapped">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Spacing="4">
                                <TextBlock Text="{Binding DisplayName}" FontWeight="Medium"/>
                                <TextBlock Text="{Binding FileName}"
                                          FontSize="11"
                                          Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>

        <Grid Grid.Row="2"
              ColumnDefinitions="*,Auto,Auto,Auto,Auto"
              Margin="0,16,0,0">
            <TextBlock Grid.Column="0"
                      Text="{Binding StatusMessage}"
                      VerticalAlignment="Center"/>

            <Button Grid.Column="1"
                   Classes="icon"
                   Command="{Binding LoadBackupsCommand}"
                   IsEnabled="{Binding !IsLoading}"
                   Margin="0,0,8,0"
                   ToolTip.Tip="刷新备份列表">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <PathIcon Data="{StaticResource IconRefresh}" Width="16" Height="16"/>
                    <TextBlock Text="刷新" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>

            <Button Grid.Column="2"
                   Classes="icon"
                   Command="{Binding CreateBackupCommand}"
                   IsEnabled="{Binding !IsLoading}"
                   Margin="0,0,8,0">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <PathIcon Data="{StaticResource IconBackup}" Width="16" Height="16"/>
                    <TextBlock Text="创建备份" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>

            <Button Grid.Column="3"
                   Classes="icon"
                   Command="{Binding RestoreBackupCommand}"
                   IsEnabled="{Binding !IsLoading}"
                   Margin="0,0,8,0">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <PathIcon Data="{StaticResource IconRestore}" Width="16" Height="16"/>
                    <TextBlock Text="恢复备份" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>

            <Button Grid.Column="4"
                   Classes="icon"
                   Command="{Binding DeleteBackupCommand}"
                   IsEnabled="{Binding !IsLoading}">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <PathIcon Data="{StaticResource IconDelete}" Width="16" Height="16"/>
                    <TextBlock Text="删除" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
        </Grid>
    </Grid>
</UserControl>
