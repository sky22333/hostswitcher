<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:HostsManager.ViewModels"
        xmlns:views="using:HostsManager.Views"
        x:Class="HostsManager.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="Hosts 管理器"
        Width="1000" Height="700"
        MinWidth="900" MinHeight="600"
        Icon="/Assets/icon.ico"
        WindowStartupLocation="CenterScreen">

    <Grid ColumnDefinitions="200,*">
        <StackPanel Grid.Column="0" Margin="12,16">
                <TextBlock Text="功能"
                          Classes="pageSubtitle"
                          Margin="12,0,0,12"/>

                <ListBox SelectedIndex="{Binding SelectedIndex}"
                        Background="Transparent"
                        BorderThickness="0">
                    <ListBoxItem>
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <PathIcon Data="{StaticResource IconEdit}" Width="18" Height="18"/>
                            <TextBlock Text="编辑 Hosts" VerticalAlignment="Center"/>
                        </StackPanel>
                    </ListBoxItem>
                    <ListBoxItem>
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <PathIcon Data="{StaticResource IconBackup}" Width="18" Height="18"/>
                            <TextBlock Text="备份管理" VerticalAlignment="Center"/>
                        </StackPanel>
                    </ListBoxItem>
                    <ListBoxItem>
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <PathIcon Data="{StaticResource IconSync}" Width="18" Height="18"/>
                            <TextBlock Text="远程同步" VerticalAlignment="Center"/>
                        </StackPanel>
                    </ListBoxItem>
                </ListBox>
        </StackPanel>

        <ContentControl Grid.Column="1"
                       Content="{Binding CurrentView}"
                       Margin="20">
            <ContentControl.DataTemplates>
                <DataTemplate DataType="vm:HostsEditorViewModel">
                    <views:HostsEditorView/>
                </DataTemplate>
                <DataTemplate DataType="vm:BackupViewModel">
                    <views:BackupView/>
                </DataTemplate>
                <DataTemplate DataType="vm:SyncViewModel">
                    <views:SyncView/>
                </DataTemplate>
            </ContentControl.DataTemplates>
        </ContentControl>
    </Grid>
</Window>
