<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:HostsManager.ViewModels"
             x:Class="HostsManager.Views.HostsEditorView"
             x:DataType="vm:HostsEditorViewModel">

    <UserControl.Styles>
        <!-- 移除 TextBox 的焦点边框 -->
        <Style Selector="TextBox:focus /template/ Border#PART_BorderElement">
            <Setter Property="BorderBrush" Value="{DynamicResource SystemControlForegroundBaseLowBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>
        <Style Selector="TextBox:pointerover /template/ Border#PART_BorderElement">
            <Setter Property="BorderBrush" Value="{DynamicResource SystemControlForegroundBaseLowBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>
    </UserControl.Styles>

    <Grid RowDefinitions="Auto,*,Auto">
        <!-- 标题栏 -->
        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="编辑 Hosts 文件" 
                      FontSize="24" 
                      FontWeight="SemiBold"
                      Margin="0,0,0,8"/>
            <TextBlock x:Name="HostsPathText"
                      Text="C:\Windows\System32\drivers\etc\hosts" 
                      FontSize="12"
                      Foreground="{DynamicResource SystemAccentColor}"
                      Cursor="Hand"
                      TextDecorations="Underline"
                      PointerPressed="OnHostsPathClicked"
                      ToolTip.Tip="点击打开文件所在目录"/>
        </StackPanel>

        <!-- 编辑器区域 -->
        <Border Grid.Row="1" 
                BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Background="{DynamicResource SystemControlBackgroundAltHighBrush}"
                ClipToBounds="True">
            <TextBox x:Name="Editor"
                    Text="{Binding HostsContent}"
                    AcceptsReturn="True"
                    AcceptsTab="True"
                    TextWrapping="NoWrap"
                    FontFamily="Consolas,Courier New,monospace"
                    FontSize="14"
                    Background="Transparent"
                    BorderThickness="0"
                    Padding="16,12"
                    Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}"
                    SelectionBrush="{DynamicResource SystemAccentColor}"
                    SelectionForegroundBrush="White"
                    CaretBrush="{DynamicResource SystemControlForegroundBaseHighBrush}"
                    ScrollViewer.HorizontalScrollBarVisibility="Auto"
                    ScrollViewer.VerticalScrollBarVisibility="Auto"/>
        </Border>

        <!-- 底部操作栏 -->
        <Grid Grid.Row="2" 
              ColumnDefinitions="*,Auto,Auto,Auto"
              Margin="0,16,0,0">
            <StackPanel Grid.Column="0" 
                       Orientation="Horizontal" 
                       Spacing="8"
                       VerticalAlignment="Center">
                <TextBlock Text="{Binding StatusMessage}" 
                          VerticalAlignment="Center"/>
                <TextBlock Text="●" 
                          Foreground="Orange"
                          IsVisible="{Binding IsModified}"
                          VerticalAlignment="Center"/>
                <TextBlock Text="已修改" 
                          IsVisible="{Binding IsModified}"
                          VerticalAlignment="Center"/>
            </StackPanel>

            <Button Grid.Column="1"
                   Content="刷新 DNS"
                   Command="{Binding FlushDnsCommand}"
                   IsEnabled="{Binding !IsLoading}"
                   Margin="0,0,8,0"
                   ToolTip.Tip="清除系统 DNS 缓存"/>

            <Button Grid.Column="2"
                   Content="重新加载"
                   Command="{Binding LoadHostsCommand}"
                   IsEnabled="{Binding !IsLoading}"
                   Margin="0,0,8,0"/>

            <Button Grid.Column="3"
                   Content="保存更改"
                   Command="{Binding SaveHostsCommand}"
                   IsEnabled="{Binding !IsLoading}"
                   Classes="accent"/>
        </Grid>
    </Grid>
</UserControl>
