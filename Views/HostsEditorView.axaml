<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:HostsManager.ViewModels"
             x:Class="HostsManager.Views.HostsEditorView"
             x:DataType="vm:HostsEditorViewModel">

    <Grid RowDefinitions="Auto,*,Auto">
        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="编辑 Hosts 文件" Classes="pageTitle" Margin="0,0,0,6"/>
            <TextBlock x:Name="HostsPathText"
                      Classes="pageSubtitle"
                      Text="C:\Windows\System32\drivers\etc\hosts"
                      Foreground="{DynamicResource SystemAccentColor}"
                      Cursor="Hand"
                      TextDecorations="Underline"
                      PointerPressed="OnHostsPathClicked"
                      ToolTip.Tip="点击打开文件所在目录"/>
        </StackPanel>

        <Border Grid.Row="1" Classes="card" ClipToBounds="True">
            <TextBox Classes="editor"
                    Text="{Binding HostsContent}"
                    Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}"
                    SelectionBrush="{DynamicResource SystemAccentColor}"
                    SelectionForegroundBrush="{DynamicResource SystemControlHighlightAltChromeWhiteBrush}"
                    CaretBrush="{DynamicResource SystemControlForegroundBaseHighBrush}"
                    ScrollViewer.HorizontalScrollBarVisibility="Auto"
                    ScrollViewer.VerticalScrollBarVisibility="Auto"/>
        </Border>

        <Grid Grid.Row="2"
              ColumnDefinitions="*,Auto,Auto,Auto"
              Margin="0,16,0,0">
            <StackPanel Grid.Column="0"
                       Orientation="Horizontal"
                       Spacing="8"
                       VerticalAlignment="Center">
                <TextBlock Text="{Binding StatusMessage}" VerticalAlignment="Center"/>
                <TextBlock Text="●"
                          Classes="warning"
                          IsVisible="{Binding IsModified}"
                          VerticalAlignment="Center"/>
                <TextBlock Text="已修改"
                          IsVisible="{Binding IsModified}"
                          VerticalAlignment="Center"/>
            </StackPanel>

            <Button Grid.Column="1"
                   Classes="icon"
                   Command="{Binding FlushDnsCommand}"
                   IsEnabled="{Binding !IsLoading}"
                   Margin="0,0,8,0"
                   ToolTip.Tip="清除系统 DNS 缓存">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <PathIcon Data="{StaticResource IconGlobe}" Width="16" Height="16"/>
                    <TextBlock Text="刷新 DNS" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>

            <Button Grid.Column="2"
                   Classes="icon"
                   Command="{Binding LoadHostsCommand}"
                   IsEnabled="{Binding !IsLoading}"
                   Margin="0,0,8,0">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <PathIcon Data="{StaticResource IconRefresh}" Width="16" Height="16"/>
                    <TextBlock Text="重新加载" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>

            <Button Grid.Column="3"
                   Classes="icon"
                   Command="{Binding SaveHostsCommand}"
                   IsEnabled="{Binding !IsLoading}">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <PathIcon Data="{StaticResource IconSave}" Width="16" Height="16"/>
                    <TextBlock Text="保存更改" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
        </Grid>
    </Grid>
</UserControl>
