<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:HostsManager.ViewModels"
             x:Class="HostsManager.Views.SyncView"
             x:DataType="vm:SyncViewModel">

    <Grid RowDefinitions="Auto,Auto,Auto,Auto">
        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="远程同步" Classes="pageTitle" Margin="0,0,0,6"/>
            <TextBlock Text="从远程 URL 下载 Hosts 配置并合并到本地"
                      Classes="pageSubtitle"/>
        </StackPanel>

        <Border Grid.Row="1" Classes="card" Padding="16" Margin="0,0,0,12">
            <StackPanel Spacing="10">
                <TextBlock Text="同步模式" FontWeight="Medium"/>
                <RadioButton Content="追加模式（保留现有内容，替换远程同步区块）"
                            IsChecked="{Binding AppendMode}"/>
                <RadioButton Content="覆盖模式（完全替换为远程内容）"
                            IsChecked="{Binding !AppendMode}"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="2" Classes="card" Padding="16" Margin="0,0,0,12">
            <StackPanel Spacing="8">
                <TextBlock Text="同步 URL" FontWeight="Medium"/>
                <TextBox Text="{Binding SyncUrl}"
                        PlaceholderText="https://example.com/hosts"/>
                <TextBlock Text="默认提供 GitHub Hosts 加速源，可直接修改 URL"
                          Classes="pageSubtitle"/>
            </StackPanel>
        </Border>

        <Grid Grid.Row="3" ColumnDefinitions="*,Auto">
            <StackPanel Grid.Column="0"
                       Orientation="Horizontal"
                       Spacing="8"
                       VerticalAlignment="Center">
                <TextBlock Text="{Binding StatusMessage}" VerticalAlignment="Center"/>
                <ProgressBar IsIndeterminate="True"
                            IsVisible="{Binding IsLoading}"
                            Width="80"
                            Height="4"
                            VerticalAlignment="Center"/>
            </StackPanel>

            <Button Grid.Column="1"
                   Classes="icon accent"
                   Command="{Binding SyncFromSourceCommand}"
                   IsEnabled="{Binding !IsLoading}">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <PathIcon Data="{StaticResource IconSync}" Width="16" Height="16"/>
                    <TextBlock Text="开始同步" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
        </Grid>
    </Grid>
</UserControl>
