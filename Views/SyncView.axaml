<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:HostsManager.ViewModels"
             x:Class="HostsManager.Views.SyncView"
             x:DataType="vm:SyncViewModel">

    <Grid RowDefinitions="Auto,*,Auto">
        <StackPanel Grid.Row="0" Margin="0,0,0,24">
            <TextBlock Text="远程同步" Classes="pageTitle" Margin="0,0,0,6"/>
            <TextBlock Text="从远程 URL 下载 Hosts 配置并合并到本地"
                      Classes="pageSubtitle"/>
        </StackPanel>

        <StackPanel Grid.Row="1" Spacing="24">
            <StackPanel Spacing="8">
                <TextBlock Text="同步模式"/>
                <RadioButton Content="追加模式（保留现有内容，替换远程同步区块）"
                            IsChecked="{Binding AppendMode}"/>
                <RadioButton Content="覆盖模式（完全替换为远程内容）"
                            IsChecked="{Binding !AppendMode}"/>
            </StackPanel>

            <StackPanel Spacing="8">
                <TextBlock Text="同步 URL"/>
                <TextBox Text="{Binding SyncUrl}"
                        PlaceholderText="https://example.com/hosts"/>
                <TextBlock Text="默认提供 GitHub Hosts 加速源，可直接修改 URL"
                          Classes="pageSubtitle"/>
            </StackPanel>
        </StackPanel>

        <Grid Grid.Row="2"
              ColumnDefinitions="*,Auto"
              Margin="0,24,0,0">
            <TextBlock Grid.Column="0"
                      Text="{Binding StatusMessage}"
                      VerticalAlignment="Center"/>

            <Button Grid.Column="1"
                   Classes="icon"
                   Command="{Binding SyncFromSourceCommand}"
                   IsEnabled="{Binding !IsLoading}">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <PathIcon Data="{StaticResource IconSync}" Width="16" Height="16"/>
                    <TextBlock Text="开始同步" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
        </Grid>
    </Grid>
</UserControl>
