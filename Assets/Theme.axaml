<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ResourceDictionary.ThemeDictionaries>
        <ResourceDictionary x:Key="Light">
            <Color x:Key="AppSurface1Color">#0A000000</Color>
            <Color x:Key="AppSurface2Color">#14000000</Color>
            <Color x:Key="AppWarningColor">#CA5010</Color>
            <SolidColorBrush x:Key="AppSurface1Brush" Color="{StaticResource AppSurface1Color}"/>
            <SolidColorBrush x:Key="AppSurface2Brush" Color="{StaticResource AppSurface2Color}"/>
            <SolidColorBrush x:Key="AppWarningBrush" Color="{StaticResource AppWarningColor}"/>
        </ResourceDictionary>
        <ResourceDictionary x:Key="Dark">
            <Color x:Key="AppSurface1Color">#12FFFFFF</Color>
            <Color x:Key="AppSurface2Color">#1FFFFFFF</Color>
            <Color x:Key="AppWarningColor">#FFB900</Color>
            <SolidColorBrush x:Key="AppSurface1Brush" Color="{StaticResource AppSurface1Color}"/>
            <SolidColorBrush x:Key="AppSurface2Brush" Color="{StaticResource AppSurface2Color}"/>
            <SolidColorBrush x:Key="AppWarningBrush" Color="{StaticResource AppWarningColor}"/>
        </ResourceDictionary>
    </ResourceDictionary.ThemeDictionaries>
</ResourceDictionary>
